# =============================================================
#  Twój Myszyniec — przykładowe zmienne środowiskowe
#  Skopiuj ten plik do `.env.local` i uzupełnij wartości.
#  Na MVP NIE są wymagane żadne klucze — pogoda działa bez klucza (Open-Meteo).
# =============================================================

# Publiczny adres URL portalu (używany w SEO, sitemap.xml, OpenGraph).
# W produkcji ustaw na docelową domenę, np. https://twoj-myszyniec.pl
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# (Opcjonalnie) Klucz OpenWeatherMap — TYLKO jeśli zdecydujesz się
# zastąpić Open-Meteo. Domyślnie nieużywany.
# OPENWEATHER_API_KEY=

# (Opcjonalnie, na przyszłość) Dane dostępowe do CMS (np. Sanity/Strapi),
# gdy zrezygnujesz z trzymania treści w plikach repozytorium.
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
